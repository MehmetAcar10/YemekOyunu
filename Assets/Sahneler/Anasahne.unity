--- !u!114 &13904815
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 13904813}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: bc2c424cbf5cc8149affc128c93afb06, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  chapters:
  - chapterName: "Ba\u015Flang\u0131\xE7"
    slides:
    - type: 0
      image: {fileID: 2800000, guid: c6b2ed14d3d8eeb468bd172d4ab3448c, type: 3}
      videoClip: {fileID: 0}
      subtitle: "\"Her \u015Fey kusursuz lezzeti bulma h\u0131rs\u0131yla ba\u015Flad\u0131.
        Vicente \u015Eefli\u011Fini zirveye ta\u015F\u0131mak i\xE7in \u015Feytanla
        el s\u0131k\u0131\u015Ft\u0131; tabaklar\u0131 kar\u015F\u0131l\u0131\u011F\u0131nda
        duygular\u0131n\u0131 satacakt\u0131.\""
    - type: 1
      image: {fileID: 0}
      videoClip: {fileID: 32900000, guid: a647313c78688154f9f262ff1f66c9f1, type: 3}
      subtitle: 
    - type: 0
      image: {fileID: 2800000, guid: e852b3ecf1a8e434da3afc6a4515e05c, type: 3}
      videoClip: {fileID: 0}
      subtitle: "\" Vicente kendi hislerini en b\xFCy\xFCk amac\u0131 i\xE7in feda
        etmeye haz\u0131rd\u0131. Saf k\xF6t\xFCl\xFC\u011Fe ruhunu, t\xFCm duygular\u0131n\u0131
        satmak kar\u015F\u0131l\u0131\u011F\u0131nda anla\u015Fma yapt\u0131lar ama
        unuttu\u011Fu \u015Fey onun \"\u015Eeytan\" olu\u015Fuydu.\""
    - type: 0
      image: {fileID: 2800000, guid: afea23e0e62cecd429c7a94eec0dad12, type: 3}
      videoClip: {fileID: 0}
      subtitle: "\"Vicente anla\u015Fma yapt\u0131\u011F\u0131 varl\u0131\u011F\u0131n
        ciddiyetinin fark\u0131na ancak ihanete u\u011Frad\u0131\u011F\u0131 vakit
        anlad\u0131. \u015Eeytan anla\u015Fmay\u0131 bozarak onun de\u011Fil sevdi\u011Fi
        e\u015Finin duygular\u0131n\u0131 ald\u0131.\""
    music: {fileID: 8300000, guid: ccc67f9118430804992d7bbaf197e21a, type: 3}
    musicVolume: 0.56
    loopMusic: 0
    isFinal: 0
  - chapterName: "H\xFCz\xFCn"
    slides:
    - type: 0
      image: {fileID: 2800000, guid: d08f0a0c255ac8143be44f6ed543fb7c, type: 3}
      videoClip: {fileID: 0}
      subtitle: " \"Bu \xFCz\xFCnt\xFC i\xE7in bile te\u015Fekk\xFCrler.\""
    music: {fileID: 8300000, guid: 49bdc09d32e5d2f41923e80852cf7f68, type: 3}
    musicVolume: 0.488
    loopMusic: 0
    isFinal: 0
  - chapterName: Korku
    slides:
    - type: 0
      image: {fileID: 2800000, guid: 768ba73bb7bd9814c86870ff9127a129, type: 3}
      videoClip: {fileID: 0}
      subtitle: "\"Korkular\u0131mlay\u0131m, ama buraday\u0131m, hayatta.\""
    music: {fileID: 8300000, guid: 389c66fc42417404085817ca0c479146, type: 3}
    musicVolume: 0.521
    loopMusic: 0
    isFinal: 0
  - chapterName: Sevgi
    slides:
    - type: 0
      image: {fileID: 2800000, guid: c41909ce490aa55448e1803519ae993b, type: 3}
      videoClip: {fileID: 0}
      subtitle: "\"\u015Eimdi k\u0131z\u0131mla, sayende sevgimizi hissedebiliyorum.
        Yeniden ve sonlu olmadan.\""
    music: {fileID: 8300000, guid: 3558a6ada02afa14eba1bcc3d041e30f, type: 3}
    musicVolume: 0.498
    loopMusic: 0
    isFinal: 0
  - chapterName: "\xD6fke"
    slides:
    - type: 0
      image: {fileID: 2800000, guid: 0a647135de3308c48b5cae1e21eb7648, type: 3}
      videoClip: {fileID: 0}
      subtitle: "\"Sen \xF6fkene yenik d\xFC\u015Ft\xFCn ben de seninle d\xFC\u015Ft\xFCm.\""
    music: {fileID: 8300000, guid: 54c256cfadc77c6478dd3a8ff27a9b90, type: 3}
    musicVolume: 0.469
    loopMusic: 0
    isFinal: 0
  - chapterName: Mutluluk
    slides:
    - type: 0
      image: {fileID: 2800000, guid: 414c194e39e5e404e853a0f8667c299c, type: 3}
      videoClip: {fileID: 0}
      subtitle: "\"T\xFCm mutlulu\u011Fum, g\xFCne\u015Fim ve \u0131\u015F\u0131\u011F\u0131md\u0131.
        Umar\u0131m ki sa\xE7lar\u0131m kadar uzun kalacakt\u0131r.\""
    - type: 0
      image: {fileID: 2800000, guid: cf5d1234fd3a2ed42a0421b27f81996c, type: 3}
      videoClip: {fileID: 0}
      subtitle: "\"ve ger\xE7ek bir hayat lezzeti. Seninle birlikte s\u0131cak yuvamda,
        \xE7i\xE7ek bah\xE7emizin kokular\u0131nda...\""
    music: {fileID: 8300000, guid: 50fb6b9ecef3a5b42910482d18aea8bb, type: 3}
    musicVolume: 0.488
    loopMusic: 0
    isFinal: 0
  fadeDuration: 0.3
  blackScreenDuration: 0.5
  subtitleFontSize: 32
  subtitleColor: {r: 1, g: 1, b: 1, a: 1}
  saveKey: CutsceneChapter
  resetProgressOnStart: 0
